{
  "version": 2,
  "functions": {
    "api/test-networks.js": { "maxDuration": 60 },
    "api/scrape.js": { "maxDuration": 30 },
    "api/verify.js": { "maxDuration": 30 },
    "api/enrich.js": { "maxDuration": 30 },
    "api/worker.js": { "maxDuration": 30 },
    "api/fetch-contacts.js": { "maxDuration": 60 },
    "api/test-auth.js": { "maxDuration": 30 },
    "api/cleanup.js": { "maxDuration": 60 },
    "api/partners.js": { "maxDuration": 60 },
    "api/save.js": { "maxDuration": 15 },
    "api/save-directory.js": { "maxDuration": 30 },
    "api/load-directory.js": { "maxDuration": 30 },
    "api/discover-global.js": { "maxDuration": 30 },
    "api/discover-network.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/worker",
      "schedule": "* * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
